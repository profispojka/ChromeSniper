{
  "manifest_version": 3,
  "name": "Drag Square Drawer",
  "version": "1.0",
  "description": "Při každém tažení myší nakreslí čtverec.",
  "permissions": ["tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}

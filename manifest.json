{
  "manifest_version": 3,
  "name": "Snipper",
  "version": "1.0.0",
  "description": "Save and annotate screenshots of areas or full pages with shift + mouse.",
  "author": "Jirka Enty",
  "homepage_url": "https://entyai.cz",
  "permissions": ["activeTab", "storage", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "dist/popup.html"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/qrcode.js", "dist/annotations.js", "dist/fullpage.js", "dist/historyModal.js", "dist/elementPicker.js", "dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}

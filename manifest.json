{
  "manifest_version": 3,
  "name": "Drag Square Drawer",
  "version": "1.0",
  "description": "Při každém tažení myší nakreslí čtverec.",
  "permissions": ["tabs", "storage", "clipboardWrite"],
  "host_permissions": ["<all_urls>", "https://0x0.st/*", "https://catbox.moe/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    },
    "default_popup": "dist/popup.html"
  },
  "commands": {
    "capture-full-page": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Snímek celé stránky"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/qrcode.js", "dist/annotations.js", "dist/fullpage.js", "dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
